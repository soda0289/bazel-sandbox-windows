+// True if `p` exists and is a directory.
+static bool OverlayIsDirectory(const std::wstring& p)
+{
+    DWORD attrs = GetFileAttributesW(p.c_str());
+    return attrs != INVALID_FILE_ATTRIBUTES && (attrs & FILE_ATTRIBUTE_DIRECTORY) != 0;
