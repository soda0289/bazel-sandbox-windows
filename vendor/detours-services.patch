+static void EnsureBackingParentDirs(const std::wstring& backingPath)
+{
+    size_t start = (backingPath.compare(0, 4, L"\\\\?\\") == 0) ? 4 : 0;
+    for (size_t i = start; i < backingPath.size(); ++i)
